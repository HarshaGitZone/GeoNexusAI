# MEMORY OPTIMIZATION FOR RENDER DEPLOYMENT
# Add these settings to reduce memory consumption and prevent timeouts

# Performance Configuration
USE_FAST_ANALYSIS=true

# Memory Optimization (Render-specific)
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
MALLOC_ARENA_MAX=2

# Render-specific optimizations
RENDER_SAFE_MODE=true
RENDER_MEMORY_LIMIT=512

# Thread pool optimization
MAX_WORKERS_RENDER=20
MAX_WORKERS_LOCAL=30

# Timeout optimization
TIMEOUT_RENDER=4
TIMEOUT_LOCAL=6
